    "require-dev": {
        "friendsofphp/php-cs-fixer": "^3.50",
        "phpstan/phpstan": "^1.10",
        "phpunit/phpunit": "^10.5",
        "waaseyaa/testing": "@dev"
    },
    "autoload": {
        "psr-4": {
            "Waaseyaa\\GitHub\\": "packages/github/src/",
            "Waaseyaa\\Engagement\\": "packages/engagement/src/"
        }
    },
    "autoload-dev": {
