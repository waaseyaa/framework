            "Waaseyaa\\Media\\Tests\\": "packages/media/tests/",
            "Waaseyaa\\Menu\\Tests\\": "packages/menu/tests/",
            "Waaseyaa\\Messaging\\Tests\\": "packages/messaging/tests/",
            "Waaseyaa\\Node\\Tests\\": "packages/node/tests/",
            "Waaseyaa\\Path\\Tests\\": "packages/path/tests/",
            "Waaseyaa\\Relationship\\Tests\\": "packages/relationship/tests/",
            "Waaseyaa\\Routing\\Tests\\": "packages/routing/tests/",
            "Waaseyaa\\Search\\Tests\\": "packages/search/tests/",
            "Waaseyaa\\SSR\\Tests\\": "packages/ssr/tests/",
