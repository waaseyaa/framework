#!/usr/bin/env bash
# Pre-push hook: fast lint + test subset before pushing.
# Install via: scripts/install-git-hooks.sh
set -euo pipefail

echo "--- pre-push checks ---"

REMOTE="${1:-origin}"
REMOTE_SHA=$(git rev-parse "$REMOTE/main" 2>/dev/null || echo "HEAD~10")
CHANGED_PHP=$(git diff --name-only "$REMOTE_SHA"...HEAD -- '*.php' 2>/dev/null || true)

# 1. PHP syntax on changed files
if [ -n "$CHANGED_PHP" ]; then
    echo "[1/3] PHP syntax (changed files)..."
    FAIL=0
    while IFS= read -r file; do
        [ -f "$file" ] && php -l "$file" > /dev/null 2>&1 || { echo "  FAIL: $file"; FAIL=1; }
    done <<< "$CHANGED_PHP"
    [ "$FAIL" -eq 0 ] && echo "  OK" || { echo "ABORT: syntax errors found"; exit 1; }
else
    echo "[1/3] PHP syntax — no changed PHP files, skipping"
fi

# 2. composer validate
echo "[2/3] composer validate..."
composer validate --no-check-all --no-check-publish > /dev/null 2>&1 \
  || { echo "  FAIL: composer.json invalid"; exit 1; }
echo "  OK"

# 3. PHPStan (if available)
if composer run-script --list 2>/dev/null | grep -q phpstan; then
    echo "[3/3] PHPStan..."
    composer phpstan > /dev/null 2>&1 \
      || { echo "  FAIL: PHPStan errors"; exit 1; }
    echo "  OK"
else
    echo "[3/3] PHPStan — not configured, skipping"
fi

echo "--- pre-push checks passed ---"
