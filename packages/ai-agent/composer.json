{
    "name": "waaseyaa/ai-agent",
    "description": "AI agent orchestration and tool execution for Waaseyaa",
    "type": "library",
    "license": "GPL-2.0-or-later",
    "repositories": [
        {"type": "path", "url": "../ai-schema"},
        {"type": "path", "url": "../access"},
        {"type": "path", "url": "../plugin"},
        {"type": "path", "url": "../cache"},
        {"type": "path", "url": "../typed-data"},
        {"type": "path", "url": "../config"}
    ],
    "require": {
        "php": ">=8.3",
        "waaseyaa/ai-schema": "@dev",
        "waaseyaa/access": "@dev"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5"
    },
    "autoload": {
        "psr-4": {
            "Waaseyaa\\AI\\Agent\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Waaseyaa\\AI\\Agent\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
