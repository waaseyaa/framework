{
    "name": "aurora/ai-pipeline",
    "description": "AI processing pipelines with queue-based execution for Aurora CMS",
    "type": "library",
    "license": "GPL-2.0-or-later",
    "require": {
        "php": ">=8.3",
        "aurora/ai-agent": "^0.1",
        "aurora/entity": "^0.1",
        "aurora/queue": "^0.1"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5"
    },
    "autoload": {
        "psr-4": {
            "Aurora\\AI\\Pipeline\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Aurora\\AI\\Pipeline\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "stable"
}
