{
    "name": "waaseyaa/mcp",
    "description": "Remote MCP server endpoint for Waaseyaa",
    "type": "library",
    "license": "GPL-2.0-or-later",
    "repositories": [
        {"type": "path", "url": "../ai-schema"},
        {"type": "path", "url": "../ai-agent"},
        {"type": "path", "url": "../routing"},
        {"type": "path", "url": "../access"},
        {"type": "path", "url": "../entity"},
        {"type": "path", "url": "../plugin"},
        {"type": "path", "url": "../cache"},
        {"type": "path", "url": "../typed-data"},
        {"type": "path", "url": "../config"},
        {"type": "path", "url": "../field"},
        {"type": "path", "url": "../entity-storage"},
        {"type": "path", "url": "../database-legacy"}
    ],
    "require": {
        "php": ">=8.3",
        "waaseyaa/ai-schema": "@dev",
        "waaseyaa/ai-agent": "@dev",
        "waaseyaa/routing": "@dev",
        "waaseyaa/access": "@dev"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5"
    },
    "autoload": {
        "psr-4": {
            "Waaseyaa\\Mcp\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Waaseyaa\\Mcp\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
