{
    "name": "waaseyaa/mcp",
    "description": "Remote MCP server endpoint for Waaseyaa",
    "type": "library",
    "license": "GPL-2.0-or-later",
    "repositories": [
        {
            "type": "path",
            "url": "../ai-schema"
        },
        {
            "type": "path",
            "url": "../ai-agent"
        },
        {
            "type": "path",
            "url": "../routing"
        },
        {
            "type": "path",
            "url": "../access"
        },
        {
            "type": "path",
            "url": "../entity"
        },
        {
            "type": "path",
            "url": "../plugin"
        },
        {
            "type": "path",
            "url": "../cache"
        },
        {
            "type": "path",
            "url": "../typed-data"
        },
        {
            "type": "path",
            "url": "../config"
        },
        {
            "type": "path",
            "url": "../field"
        },
        {
            "type": "path",
            "url": "../entity-storage"
        },
        {
            "type": "path",
            "url": "../database-legacy"
        },
        {
            "type": "path",
            "url": "../api"
        },
        {
            "type": "path",
            "url": "../ai-vector"
        },
        {
            "type": "path",
            "url": "../workflows"
        }
    ],
    "require": {
        "php": ">=8.4",
        "waaseyaa/ai-schema": "^0.1",
        "waaseyaa/ai-agent": "^0.1",
        "waaseyaa/routing": "^0.1",
        "waaseyaa/access": "^0.1",
        "waaseyaa/cache": "^0.1",
        "waaseyaa/api": "^0.1",
        "waaseyaa/ai-vector": "^0.1",
        "waaseyaa/entity": "^0.1",
        "waaseyaa/workflows": "^0.1"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5"
    },
    "autoload": {
        "psr-4": {
            "Waaseyaa\\Mcp\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Waaseyaa\\Mcp\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "extra": {
        "branch-alias": {
            "dev-main": "0.1.x-dev",
            "dev-develop/v1.1": "0.1.x-dev"
        }
    }
}
