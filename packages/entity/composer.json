{
    "name": "waaseyaa/entity",
    "description": "Entity type system \u2014 types, interfaces, lifecycle, queries. No storage.",
    "type": "library",
    "license": "GPL-2.0-or-later",
    "repositories": [
        {
            "type": "path",
            "url": "../cache"
        },
        {
            "type": "path",
            "url": "../plugin"
        },
        {
            "type": "path",
            "url": "../typed-data"
        },
        {
            "type": "path",
            "url": "../config"
        },
        {
            "type": "path",
            "url": "../foundation"
        },
        {
            "type": "path",
            "url": "../validation"
        }
    ],
    "require": {
        "php": ">=8.4",
        "waaseyaa/typed-data": "^0.1",
        "waaseyaa/plugin": "^0.1",
        "waaseyaa/cache": "^0.1",
        "waaseyaa/config": "^0.1",
        "waaseyaa/foundation": "^0.1",
        "waaseyaa/validation": "^0.1",
        "symfony/event-dispatcher": "^7.3",
        "symfony/uid": "^7.3",
        "symfony/validator": "^7.3"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5"
    },
    "autoload": {
        "psr-4": {
            "Waaseyaa\\Entity\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Waaseyaa\\Entity\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "extra": {
        "branch-alias": {
            "dev-main": "0.1.x-dev",
            "dev-develop/v1.1": "0.1.x-dev"
        }
    }
}
