{
    "name": "waaseyaa/ai-vector",
    "description": "Vector embedding storage and similarity search for Waaseyaa",
    "type": "library",
    "license": "GPL-2.0-or-later",
    "repositories": [
        {
            "type": "path",
            "url": "../entity"
        },
        {
            "type": "path",
            "url": "../cache"
        },
        {
            "type": "path",
            "url": "../plugin"
        },
        {
            "type": "path",
            "url": "../typed-data"
        },
        {
            "type": "path",
            "url": "../config"
        },
        {
            "type": "path",
            "url": "../queue"
        },
        {
            "type": "path",
            "url": "../api"
        },
        {
            "type": "path",
            "url": "../access"
        },
        {
            "type": "path",
            "url": "../workflows"
        }
    ],
    "require": {
        "php": ">=8.3",
        "waaseyaa/entity": "^0.1",
        "waaseyaa/queue": "^0.1",
        "waaseyaa/api": "^0.1",
        "waaseyaa/access": "^0.1",
        "waaseyaa/workflows": "^0.1"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5"
    },
    "autoload": {
        "psr-4": {
            "Waaseyaa\\AI\\Vector\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Waaseyaa\\AI\\Vector\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "extra": {
        "branch-alias": {
            "dev-develop/v1.1": "0.1.x-dev"
        }
    }
}
