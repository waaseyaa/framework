{
    "name": "waaseyaa/ai-vector",
    "description": "Vector embedding storage and similarity search for Waaseyaa",
    "type": "library",
    "license": "GPL-2.0-or-later",
    "repositories": [
        {"type": "path", "url": "../entity"},
        {"type": "path", "url": "../cache"},
        {"type": "path", "url": "../plugin"},
        {"type": "path", "url": "../typed-data"},
        {"type": "path", "url": "../config"},
        {"type": "path", "url": "../queue"},
        {"type": "path", "url": "../api"},
        {"type": "path", "url": "../access"}
    ],
    "require": {
        "php": ">=8.3",
        "waaseyaa/entity": "@dev",
        "waaseyaa/queue": "@dev",
        "waaseyaa/api": "@dev",
        "waaseyaa/access": "@dev"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5"
    },
    "autoload": {
        "psr-4": {
            "Waaseyaa\\AI\\Vector\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Waaseyaa\\AI\\Vector\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
