{
    "name": "aurora/cache",
    "description": "Cache bins with cache tag invalidation for Aurora CMS",
    "type": "library",
    "license": "GPL-2.0-or-later",
    "require": {
        "php": ">=8.3",
        "psr/cache": "^3.0",
        "psr/simple-cache": "^3.0"
    },
    "suggest": {
        "aurora/entity": "Required for EntityCacheInvalidator listener",
        "aurora/config": "Required for ConfigCacheInvalidator listener"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5"
    },
    "autoload": {
        "psr-4": {
            "Aurora\\Cache\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Aurora\\Cache\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "stable"
}
