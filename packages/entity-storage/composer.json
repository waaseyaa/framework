{
    "name": "aurora/entity-storage",
    "description": "Pluggable entity persistence. v0.1.0: SQL storage behind clean interfaces.",
    "type": "library",
    "license": "GPL-2.0-or-later",
    "repositories": [
        {"type": "path", "url": "../entity"},
        {"type": "path", "url": "../field"},
        {"type": "path", "url": "../cache"},
        {"type": "path", "url": "../database-legacy"},
        {"type": "path", "url": "../plugin"},
        {"type": "path", "url": "../typed-data"},
        {"type": "path", "url": "../config"}
    ],
    "require": {
        "php": ">=8.3",
        "aurora/entity": "@dev",
        "aurora/field": "@dev",
        "aurora/cache": "@dev",
        "aurora/database-legacy": "@dev",
        "symfony/event-dispatcher": "^7.3"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5"
    },
    "autoload": {
        "psr-4": {
            "Aurora\\EntityStorage\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Aurora\\EntityStorage\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
