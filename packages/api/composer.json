{
    "name": "aurora/api",
    "description": "RESTful JSON:API resource layer for Aurora CMS",
    "type": "library",
    "license": "GPL-2.0-or-later",
    "require": {
        "php": ">=8.3",
        "aurora/entity": "^0.1",
        "aurora/field": "^0.1",
        "aurora/routing": "^0.1",
        "aurora/access": "^0.1",
        "symfony/serializer": "^7.3"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5"
    },
    "autoload": {
        "psr-4": {
            "Aurora\\Api\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Aurora\\Api\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "stable"
}
