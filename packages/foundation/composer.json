{
    "name": "waaseyaa/foundation",
    "description": "Core framework primitives: service providers, domain events, results, error handling",
    "type": "library",
    "license": "GPL-2.0-or-later",
    "require": {
        "php": ">=8.4",
        "doctrine/dbal": "^4.0",
        "symfony/dependency-injection": "^7.0",
        "symfony/event-dispatcher": "^7.0",
        "symfony/http-foundation": "^7.0",
        "symfony/messenger": "^7.0",
        "symfony/uid": "^7.0",
        "waaseyaa/queue": "^0.1"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5"
    },
    "autoload": {
        "psr-4": {
            "Waaseyaa\\Foundation\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Waaseyaa\\Foundation\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "extra": {
        "waaseyaa": {
            "providers": [
                "Waaseyaa\\Foundation\\FoundationServiceProvider"
            ]
        },
        "branch-alias": {
            "dev-main": "0.1.x-dev",
            "dev-develop/v1.1": "0.1.x-dev"
        }
    }
}
