{
    "name": "waaseyaa/access",
    "description": "Access control and permission system for Waaseyaa",
    "type": "library",
    "license": "GPL-2.0-or-later",
    "repositories": [
        {"type": "path", "url": "../entity"},
        {"type": "path", "url": "../plugin"},
        {"type": "path", "url": "../cache"},
        {"type": "path", "url": "../typed-data"},
        {"type": "path", "url": "../config"}
    ],
    "require": {
        "php": ">=8.3",
        "waaseyaa/entity": "@dev",
        "waaseyaa/plugin": "@dev"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5"
    },
    "autoload": {
        "psr-4": {
            "Waaseyaa\\Access\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Waaseyaa\\Access\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
