#!/usr/bin/env bash
# Mechanical convergence preflight for Waaseyaa apps.
# See docs/specs/per-site-convergence-audit.md in the Waaseyaa monorepo.
set -euo pipefail
ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$ROOT"

err() {
    echo "waaseyaa-audit-site: $*" >&2
    exit 1
}

[[ -f composer.json ]] || err "composer.json missing"
[[ -f bin/waaseyaa ]] || err "bin/waaseyaa missing"
[[ -f bin/waaseyaa-version ]] || err "bin/waaseyaa-version missing"
[[ -x bin/waaseyaa ]] || err "bin/waaseyaa not executable (run: chmod +x bin/waaseyaa)"
[[ -x bin/waaseyaa-version ]] || err "bin/waaseyaa-version not executable (run: chmod +x bin/waaseyaa-version)"

composer validate --no-check-publish
composer install --no-interaction --dry-run

./bin/waaseyaa-version --report-only
echo "waaseyaa-audit-site: OK"
